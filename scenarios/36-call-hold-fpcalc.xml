<!-- Register with 90002 and receive a call from 90001 and put call on hold -->
<config tag="cp">
    <section type="voip_patrol">
        <actions>
            {% include "helpers/codecs-default.j2" %}
            {% with endpoint = 90002 %}
            {% include "helpers/register-200.j2" %}
            {% endwith %}
            <action type="wait" complete="true" ms="2000"/>
            <action type="accept" label="Receive call on {{ a.90002.username }} from {{ a.90001.label }}"
                call_count="1"
                match_account="{{ a.90002.username }}"
                hangup="25"
                ring_duration="2"
                code="200" reason="OK"
                transport="{{ a.90002.transport }}"
                srtp="{{ a.90002.srtp }}"
                play="{{ c.play_file }}"
                record="{{ scenario_name }}_1.wav">
                <check-header name="From" regex="^.*sip:\+412276{{ a.90001.label }}@.*$"/>
            </action>
            <action type="call" label="Call {{ a.90001.label }} -> {{ a.90002.label }}"
                transport="tls"
                expected_cause_code="200"
                caller="{{ a.90001.label }}@{{ c.domain }}"
                callee="{{ a.90002.label }}@{{ c.domain }}"
                from="sip:{{ a.90001.label }}@{{ c.domain }}"
                to_uri="{{ a.90002.label }}@{{ c.domain }}"
                max_duration="30" hangup="27"
                auth_username="{{ a.90001.username }}"
                password="{{ a.90001.password }}"
                realm="{{ c.domain }}"
                max_ring_duration="15"
                srtp="{{ a.90001.srtp }}"
                play="{{ c.play_file_2 }}"
                record="{{ scenario_name }}_2.wav"
            />
            <action type="wait" ms="5000"/>
            <!-- Pressing the "hold" button on 90002 -->
            <action type="hold" label="Put call on hold via 90002"
                caller="{{ a.90002.username }}"
            />
            <action type="wait" ms="10000"/>
            <!-- Pressing the "hold" button on 90002 again after 10 sec-->
            <action type="unhold" label="Take call from hold via 90002"
                caller="{{ a.90002.username }}"
            />
            <action type="wait" complete="true" ms="45000"/>
        </actions>
    </section>
    <section type="media_check">
        <actions>
            <action type="sox"
                sox_filter="length s -ge 2.6; length s -le 3.4; maximum amplitude -ge 0.2; maximum amplitude -le 0.3"
                file="{{ scenario_name }}_1.wav"
            />
            <!-- Checking part of the call after taking call off-hold. See documentation at https://github.com/igorolhovskiy/voip_patrol -->
